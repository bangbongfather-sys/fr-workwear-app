# Cloudflare Workers 정적 자산에서 제외할 패턴 (gitignore 문법).
# assets.directory가 프로젝트 루트(".")라 dev 도구/소스 파일이 다 자산으로 잡힘 → 명시적으로 제외.

# Node 의존성 (특히 workerd.exe 85MB가 25MB 제한 초과)
node_modules/
package.json
package-lock.json

# Worker 엔트리/설정 (자산 아님)
worker.js
worker-src/
wrangler.jsonc
tsconfig.json
tsconfig.tsbuildinfo

# 개발 서버
start-server.ps1
serve.py

# 빌드/캐시
.wrangler/
.build-dryrun/
.git/
.dev.vars
.env
.env.local

# 에디터/IDE
.claude/
.vscode/
.idea/

# 스크립트 (DB 일괄 입력 등 dev only)
scripts/
scratch/

# 문서
*.md
docs/
.gitignore
.assetsignore
