{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && git pull 2>&1 | tail -5",
            "statusMessage": "GitHub에서 최신 코드 가져오는 중..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && git add -A && git diff --staged --quiet || (git commit -m \"auto: $(hostname -s) $(date '+%Y-%m-%d %H:%M')\" && git push)",
            "statusMessage": "GitHub에 저장 중..."
          }
        ]
      }
    ]
  }
}
